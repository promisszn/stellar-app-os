# ─── Network ──────────────────────────────────────────────────────────────────
# Which Stellar network to connect to: "testnet" | "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# ─── RPC / Horizon URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ─── Network Passphrase ───────────────────────────────────────────────────────
# Testnet:  "Test SDF Network ; September 2015"
# Mainnet:  "Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ─── USDC Issuer ──────────────────────────────────────────────────────────────
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ─── TREE Token Issuer ────────────────────────────────────────────────────────
# The account that issues TREE tokens (carbon credits) on this network.
NEXT_PUBLIC_TREE_ISSUER=REPLACE_WITH_TREE_ISSUER_ADDRESS

# ─── Carbon Credit (CARBON) Issuer ───────────────────────────────────────────
NEXT_PUBLIC_CARBON_CREDIT_ISSUER=GDUKMGUGDORQJH6YWY4RHDE6GV3NCYCBN3MORXYL43TSJPCCZFLNOA5H

# ─── Contract IDs (Soroban) ───────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_TREE_ESCROW=REPLACE_WITH_TREE_ESCROW_CONTRACT_ID
NEXT_PUBLIC_CONTRACT_ESCROW_MILESTONE=REPLACE_WITH_ESCROW_MILESTONE_CONTRACT_ID
NEXT_PUBLIC_CONTRACT_LOCATION_PROOF=REPLACE_WITH_LOCATION_PROOF_CONTRACT_ID
NEXT_PUBLIC_CONTRACT_NULLIFIER_REGISTRY=REPLACE_WITH_NULLIFIER_REGISTRY_CONTRACT_ID

# ─── Platform Addresses ───────────────────────────────────────────────────────
# Receives 70% of each donation (direct tree planting)
NEXT_PUBLIC_PLANTING_ADDRESS=GABEMKJNR4GK7M4FROGA7I7PG63N2CKE3EGDSBSISG56SVL2O3KRNDXA
# Receives 30% of each donation (replanting buffer fund)
NEXT_PUBLIC_REPLANTING_BUFFER_ADDRESS=GBUQWP3BOUZX34TOND2QV7QQ7K7VJTG6VSE62MFPXXXIAGKZ6YTDCXI
# Receives bulk purchase payments
NEXT_PUBLIC_BULK_RECIPIENT_ADDRESS=GABEMKJNR4GK7M4FROGA7I7PG63N2CKE3EGDSBSISG56SVL2O3KRNDXA

# ─── Anchor API ───────────────────────────────────────────────────────────────
# SEP-24 / SEP-31 anchor endpoint for on/off-ramp
NEXT_PUBLIC_ANCHOR_API_URL=https://testanchor.stellar.org
# Anchor home domain (used for TOML discovery)
NEXT_PUBLIC_ANCHOR_HOME_DOMAIN=testanchor.stellar.org

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
